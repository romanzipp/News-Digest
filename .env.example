# Server
LISTEN_ADDR=:8080
BASE_URL=http://localhost:8080

# Database: "sqlite" or "postgres"
DB_DRIVER=sqlite
DB_DSN=file:data/news.db?_journal=WAL&_fk=1
# DB_DSN=postgres://user:pass@localhost:5432/news?sslmode=disable

# Auth
SESSION_SECRET=change-me-to-random-64-chars
REGISTRATION_ENABLED=true

# AI (OpenAI-compatible endpoint)
AI_ENDPOINT=https://api.openai.com/v1
AI_API_KEY=sk-...
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_MAX_CONTEXT=128000

# Scheduling (cron expressions)
FETCH_CRON=0 5 * * *
DIGEST_CRON=0 6 * * *

# Image proxy
IMAGE_PROXY_ENABLED=true
